doctype html 

html
  head 
    block page_title 
      title First app: Hello World!
    meta(charset="UTF-8")
    link(rel="stylesheet" href="stylesheets/application.css")
  body 
    nav
      ul
        li 
          a(href="/english" class=englishClass)
            img.flag(src="/images/flag-of-USA.png"
            alt="US flag"
            title="Go to US English site")
        li
          a(href="/french" class=frenchClass)
            img.flag(src="/images/flag-of-France.png"
            alt="Drapeau de la France"
            title="Aller sur le site français")
        li
          a(href="/japanese" class=japaneseClass)
            img.flag(src="/images/flag-of-Japan.png"
            alt="日本の国旗"
            title="日本語版ページを見る")
        li
          a(href="/serbian" class=serbianClass)
            img.flag(src="/images/flag-of-Serbia.png"
            alt="Застава Србије"
            title="Идите на српски сајт")
    
    header 
      block greeting
        h1 Hello World! 

    main 
      block first_app
        p This is my first app!
        img(src="images/earth.jpg" alt="The Earth" title="The Earth")